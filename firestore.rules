rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function currentUserExists() {
      return signedIn() && exists(userDocPath(request.auth.uid));
    }

    function currentUserData() {
      return get(userDocPath(request.auth.uid)).data;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function normalizedUserRole(data) {
      return data.role is string &&
          (data.role == "user" || data.role == "author" || data.role == "admin")
        ? data.role
        : "user";
    }

    function normalizedAccountStatus(data) {
      return data.accountStatus is string &&
          (data.accountStatus == "active" || data.accountStatus == "deleted")
        ? data.accountStatus
        : "active";
    }

    function isActiveUserDoc(data) {
      return normalizedAccountStatus(data) != "deleted";
    }

    function currentUserIsActive() {
      return currentUserExists() && isActiveUserDoc(currentUserData());
    }

    function currentUserRole() {
      return currentUserExists()
        ? normalizedUserRole(currentUserData())
        : "user";
    }

    function isAdmin() {
      return currentUserIsActive() && currentUserRole() == "admin";
    }

    function isAuthorOrAdmin() {
      return currentUserIsActive() &&
        (currentUserRole() == "author" || currentUserRole() == "admin");
    }

    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function isValidUsernameValue(value) {
      return value is string &&
        value.size() >= 3 &&
        value.size() <= 20 &&
        value.matches("^[a-z0-9._-]+$");
    }

    function hasNormalizedUsernamePair(username, usernameLower) {
      return isValidUsernameValue(username) &&
        isValidUsernameValue(usernameLower) &&
        username == usernameLower;
    }

    function currentSignInProvider() {
      return signedIn() && request.auth.token.firebase.sign_in_provider is string
        ? request.auth.token.firebase.sign_in_provider
        : "";
    }

    function isValidProvider(provider) {
      return provider == "password" || provider == "google" || provider == "apple";
    }

    function normalizedProfileProvider(data) {
      return data.provider is string &&
          isValidProvider(data.provider)
        ? data.provider
        : currentSignInProvider() == "google.com"
          ? "google"
          : currentSignInProvider() == "apple.com"
            ? "apple"
            : currentSignInProvider() == "password"
              ? "password"
            : "";
    }

    function hasMatchingProfileProvider(provider) {
      return (provider == "password" && currentSignInProvider() == "password") ||
        (provider == "google" && currentSignInProvider() == "google.com") ||
        (provider == "apple" && currentSignInProvider() == "apple.com");
    }

    function isOwnPost(data) {
      return signedIn() && (
        data.createdBy == request.auth.uid ||
        (request.auth.token.email is string && data.createdByEmail == request.auth.token.email)
      );
    }

    function isPublishedPost(data) {
      return data.status == "published";
    }

    match /categories/{categoryId} {
      function hasCategoryShape() {
        return request.resource.data.id == categoryId &&
          request.resource.data.name is string &&
          request.resource.data.name.size() > 0 &&
          request.resource.data.slug is string &&
          request.resource.data.slug == categoryId &&
          (
            !request.resource.data.keys().hasAny(["createdBy"]) ||
            request.resource.data.createdBy is string
          ) &&
          (
            !request.resource.data.keys().hasAny(["createdByEmail"]) ||
            request.resource.data.createdByEmail is string
          ) &&
          request.resource.data.keys().hasOnly([
            "id",
            "name",
            "slug",
            "createDate",
            "uploadDate",
            "createdBy",
            "createdByEmail"
          ]);
      }

      allow read: if true;
      allow create, update: if isAdmin() && hasCategoryShape();
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      function validPostStatus(status) {
        return status == "draft" || status == "pending" || status == "published";
      }

      function validPostAuthorRole(role) {
        return role == "author" || role == "admin";
      }

      function isAuthorCreate() {
        return isAuthorOrAdmin() &&
          request.resource.data.id == postId &&
          request.resource.data.createdBy == request.auth.uid &&
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.authorRole == currentUserRole() &&
          validPostAuthorRole(request.resource.data.authorRole) &&
          request.resource.data.updatedBy == request.auth.uid &&
          validPostStatus(request.resource.data.status) &&
          (request.resource.data.status == "draft" || request.resource.data.status == "pending") &&
          request.resource.data.publishedAt == null &&
          request.resource.data.approvedAt == null &&
          request.resource.data.approvedBy == null &&
          request.resource.data.approvedByEmail == null;
      }

      function isAuthorDraftOrPendingUpdate() {
        return isAuthorOrAdmin() &&
          isOwnPost(resource.data) &&
          isOwnPost(request.resource.data) &&
          request.resource.data.updatedBy == request.auth.uid &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "slug",
            "title",
            "content",
            "contentHtml",
            "featureImageUrl",
            "youtubeVideoUrl",
            "category",
            "status",
            "uploadDate",
            "authorId",
            "authorRole",
            "authorDisplayName",
            "authorUsername",
            "authorPhotoURL",
            "updatedBy",
            "updatedByEmail",
            "submittedAt",
            "publishedAt",
            "approvedAt",
            "approvedBy",
            "approvedByEmail"
          ]) &&
          request.resource.data.authorRole == currentUserRole() &&
          validPostAuthorRole(request.resource.data.authorRole) &&
          (request.resource.data.status == "draft" || request.resource.data.status == "pending") &&
          request.resource.data.publishedAt == null &&
          request.resource.data.approvedAt == null &&
          request.resource.data.approvedBy == null &&
          request.resource.data.approvedByEmail == null;
      }

      function isAuthorTrashOrRestore() {
        return isAuthorOrAdmin() &&
          isOwnPost(resource.data) &&
          isOwnPost(request.resource.data) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "deletedAt",
            "deletedBy",
            "deletedByEmail",
            "uploadDate"
          ]) &&
          (
            (
              request.resource.data.deletedAt == null &&
              request.resource.data.deletedBy == null &&
              request.resource.data.deletedByEmail == null
            ) ||
            (
              request.resource.data.deletedAt != null &&
              request.resource.data.deletedBy == request.auth.uid &&
              request.resource.data.deletedByEmail ==
                (request.auth.token.email is string ? request.auth.token.email : "")
            )
          ) &&
          request.resource.data.status == resource.data.status &&
          request.resource.data.publishedAt == resource.data.publishedAt &&
          request.resource.data.approvedAt == resource.data.approvedAt &&
          request.resource.data.approvedBy == resource.data.approvedBy &&
          request.resource.data.approvedByEmail == resource.data.approvedByEmail;
      }

      function isAuthorIdentityRefresh() {
        return isAuthorOrAdmin() &&
          isOwnPost(resource.data) &&
          isOwnPost(request.resource.data) &&
          request.resource.data.authorId == resource.data.authorId &&
          request.resource.data.authorRole == resource.data.authorRole &&
          request.resource.data.createdBy == resource.data.createdBy &&
          request.resource.data.createdByEmail == resource.data.createdByEmail &&
          request.resource.data.status == resource.data.status &&
          request.resource.data.submittedAt == resource.data.submittedAt &&
          request.resource.data.publishedAt == resource.data.publishedAt &&
          request.resource.data.approvedAt == resource.data.approvedAt &&
          request.resource.data.approvedBy == resource.data.approvedBy &&
          request.resource.data.approvedByEmail == resource.data.approvedByEmail &&
          request.resource.data.deletedAt == resource.data.deletedAt &&
          request.resource.data.deletedBy == resource.data.deletedBy &&
          request.resource.data.deletedByEmail == resource.data.deletedByEmail &&
          request.resource.data.authorDisplayName is string &&
          request.resource.data.authorUsername is string &&
          request.resource.data.authorPhotoURL is string &&
          request.resource.data.updatedBy == request.auth.uid &&
          request.resource.data.updatedByEmail ==
            (request.auth.token.email is string ? request.auth.token.email : "") &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "authorDisplayName",
            "authorUsername",
            "authorPhotoURL",
            "updatedBy",
            "updatedByEmail",
            "uploadDate"
          ]);
      }

      // Compatibility note:
      // Public queries in the app only filter on status == "published".
      // Because the client does not query deletedAt == null, published recycled posts
      // cannot be hidden at the rule layer without breaking those queries.
      allow read: if isPublishedPost(resource.data) || isAdmin() || (isAuthorOrAdmin() && isOwnPost(resource.data));
      allow create: if isAdmin() || isAuthorCreate();
      allow update: if isAdmin() ||
        isAuthorDraftOrPendingUpdate() ||
        isAuthorTrashOrRestore() ||
        isAuthorIdentityRefresh();
      allow delete: if isAdmin() || (isAuthorOrAdmin() && isOwnPost(resource.data));
    }

    match /favorites/{favoriteId} {
      function hasFavoriteShape() {
        return request.resource.data.id == favoriteId &&
          request.resource.data.uid == request.auth.uid &&
          request.resource.data.userEmail is string &&
          request.resource.data.postId is string &&
          request.resource.data.postTitle is string &&
          request.resource.data.postSlug is string &&
          request.resource.data.keys().hasOnly([
            "id",
            "uid",
            "userEmail",
            "postId",
            "postTitle",
            "postSlug",
            "createDate",
            "uploadDate"
          ]);
      }

      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create, update: if currentUserIsActive() &&
        hasFavoriteShape();
      allow delete: if (signedIn() && resource.data.uid == request.auth.uid) || isAdmin();
    }

    match /authorFollows/{followId} {
      function targetAuthorExists(authorId) {
        return authorId is string && authorId != "" && exists(userDocPath(authorId));
      }

      function targetAuthorData(authorId) {
        return get(userDocPath(authorId)).data;
      }

      function isFollowableAuthor(authorId) {
        return targetAuthorExists(authorId) &&
          isActiveUserDoc(targetAuthorData(authorId)) &&
          (
            targetAuthorData(authorId).role == "author" ||
            targetAuthorData(authorId).role == "admin"
          );
      }

      function hasAuthorFollowShape() {
        return request.resource.data.id == followId &&
          request.resource.data.uid == request.auth.uid &&
          request.resource.data.userEmail is string &&
          request.resource.data.authorId is string &&
          request.resource.data.authorId != request.auth.uid &&
          request.resource.data.authorUsername is string &&
          request.resource.data.authorDisplayName is string &&
          request.resource.data.keys().hasOnly([
            "id",
            "uid",
            "userEmail",
            "authorId",
            "authorUsername",
            "authorDisplayName",
            "createDate",
            "uploadDate"
          ]);
      }

      allow read: if signedIn() &&
        (resource.data.uid == request.auth.uid || resource.data.authorId == request.auth.uid);
      allow create, update: if currentUserIsActive() &&
        hasAuthorFollowShape() &&
        isFollowableAuthor(request.resource.data.authorId);
      allow delete: if isAdmin() || (
        signedIn() &&
        (resource.data.uid == request.auth.uid || resource.data.authorId == request.auth.uid)
      );
    }

    match /pushTokens/{tokenId} {
      function isValidPushTokenProvider(provider) {
        return provider == "fcm" || provider == "apns" || provider == "expo";
      }

      function hasValidPushTokenDocId() {
        return !request.resource.data.keys().hasAny(["installationId"]) ||
          tokenId == (request.auth.uid + "%3A" + request.resource.data.installationId);
      }

      function hasPushTokenShape() {
        return request.resource.data.uid == request.auth.uid &&
          hasValidPushTokenDocId() &&
          request.resource.data.token is string &&
          request.resource.data.token.size() > 0 &&
          (
            !request.resource.data.keys().hasAny(["installationId"]) ||
            (
              request.resource.data.installationId is string &&
              request.resource.data.installationId.size() > 0
            )
          ) &&
          request.resource.data.isActive == true &&
          request.resource.data.platform is string &&
          (
            !request.resource.data.keys().hasAny(["provider"]) ||
            (
              request.resource.data.provider is string &&
              isValidPushTokenProvider(request.resource.data.provider)
            )
          ) &&
          (request.resource.data.appOwnership == null || request.resource.data.appOwnership is string) &&
          (request.resource.data.deviceName == null || request.resource.data.deviceName is string) &&
          (request.resource.data.deviceBrand == null || request.resource.data.deviceBrand is string) &&
          request.resource.data.keys().hasOnly([
            "uid",
            "token",
            "installationId",
            "isActive",
            "platform",
            "provider",
            "appOwnership",
            "deviceName",
            "deviceBrand",
            "lastAuthenticatedAt",
            "updatedAt"
          ]);
      }

      allow read: if (signedIn() && resource.data.uid == request.auth.uid) || isAdmin();
      allow create, update: if currentUserIsActive() &&
        hasPushTokenShape();
      allow delete: if (signedIn() && resource.data.uid == request.auth.uid) || isAdmin();
    }

    match /usernames/{usernameId} {
      function isValidUsernameMapping(uid) {
        return request.resource.data.uid == uid &&
          hasNormalizedUsernamePair(
            request.resource.data.username,
            request.resource.data.usernameLower
          ) &&
          request.resource.data.username == usernameId &&
          request.resource.data.usernameLower == usernameId &&
          isNonEmptyString(request.resource.data.email) &&
          request.resource.data.keys().hasOnly([
            "uid",
            "username",
            "usernameLower",
            "email",
            "updatedAt"
          ]);
      }

      allow get: if true;
      allow list: if false;
      allow create: if signedIn() &&
        (
          (request.resource.data.uid == request.auth.uid &&
            isValidUsernameMapping(request.auth.uid)) ||
          (isAdmin() && isValidUsernameMapping(request.resource.data.uid))
        );
      allow update: if signedIn() &&
        (
          (resource.data.uid == request.auth.uid &&
            isValidUsernameMapping(request.auth.uid)) ||
          (isAdmin() &&
            resource.data.uid == request.resource.data.uid &&
            isValidUsernameMapping(request.resource.data.uid))
        );
      allow delete: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
    }

      match /users/{uid} {
      function hasAuthorEligibleProfile(data) {
        return isNonEmptyString(data.firstName) &&
          hasNormalizedUsernamePair(data.username, data.usernameLower) &&
          isNonEmptyString(data.gender) &&
          isNonEmptyString(data.bio);
      }

      function isAdminManagedRoleUpdate() {
        return isAdmin() &&
          !isSelf(uid) &&
          resource.data.role != "admin" &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "role",
            "accountStatus",
            "deletedAt",
            "deletedBy",
            "deletedByEmail",
            "updatedAt"
          ]) &&
          (request.resource.data.role == "user" || request.resource.data.role == "author") &&
          request.resource.data.accountStatus == "active" &&
          request.resource.data.deletedAt == null &&
          request.resource.data.deletedBy == null &&
          request.resource.data.deletedByEmail == null;
      }

      function isAdminManagedDeleteUpdate() {
        return isAdmin() &&
          !isSelf(uid) &&
          resource.data.role != "admin" &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "role",
            "accountStatus",
            "deletedAt",
            "deletedBy",
            "deletedByEmail",
            "updatedAt"
          ]) &&
          request.resource.data.role == "user" &&
          request.resource.data.accountStatus == "deleted" &&
          request.resource.data.deletedAt != null &&
          request.resource.data.deletedBy == request.auth.uid &&
          request.resource.data.deletedByEmail ==
            (currentUserData().email is string ? currentUserData().email : "");
      }

      function isSelfProfileCreate() {
        return isSelf(uid) &&
          request.resource.data.uid == uid &&
          request.auth.token.email is string &&
          request.resource.data.email == request.auth.token.email &&
          hasNormalizedUsernamePair(
            request.resource.data.username,
            request.resource.data.usernameLower
          ) &&
          normalizedUserRole(request.resource.data) == "user" &&
          normalizedAccountStatus(request.resource.data) == "active" &&
          isValidProvider(request.resource.data.provider) &&
          hasMatchingProfileProvider(request.resource.data.provider) &&
          request.resource.data.keys().hasAll([
            "uid",
            "username",
            "usernameLower",
            "firstName",
            "lastName",
            "email",
            "provider",
            "displayName",
            "gender",
            "bio",
            "updatedAt",
            "lastLoginAt"
          ]) &&
          request.resource.data.keys().hasOnly([
            "uid",
            "username",
            "usernameLower",
            "firstName",
            "lastName",
            "email",
            "role",
            "accountStatus",
            "provider",
            "displayName",
            "photoURL",
            "gender",
            "bio",
            "updatedAt",
            "lastLoginAt"
          ]);
      }

      function isSelfAuthorEnableUpdate() {
        return isSelf(uid) &&
          currentUserIsActive() &&
          normalizedUserRole(resource.data) == "user" &&
          normalizedAccountStatus(resource.data) == "active" &&
          request.resource.data.uid == resource.data.uid &&
          request.resource.data.email == resource.data.email &&
          request.resource.data.provider == normalizedProfileProvider(resource.data) &&
          hasMatchingProfileProvider(request.resource.data.provider) &&
          hasAuthorEligibleProfile(request.resource.data) &&
          request.resource.data.role == "author" &&
          request.resource.data.accountStatus == "active" &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "role",
            "accountStatus",
            "updatedAt"
          ]);
      }

      function isSelfProfileUpdate() {
        return isSelf(uid) &&
          currentUserIsActive() &&
          request.resource.data.uid == resource.data.uid &&
          request.resource.data.email == resource.data.email &&
          hasNormalizedUsernamePair(
            request.resource.data.username,
            request.resource.data.usernameLower
          ) &&
          request.resource.data.provider == normalizedProfileProvider(resource.data) &&
          hasMatchingProfileProvider(request.resource.data.provider) &&
          request.resource.data.role == normalizedUserRole(resource.data) &&
          request.resource.data.accountStatus == normalizedAccountStatus(resource.data) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "username",
            "usernameLower",
            "firstName",
            "lastName",
            "displayName",
            "photoURL",
            "gender",
            "bio",
            "updatedAt",
            "lastLoginAt",
            "role",
            "accountStatus",
            "provider"
          ]);
      }

      function isSelfDeleteUpdate() {
        return isSelf(uid) &&
          isActiveUserDoc(resource.data) &&
          request.resource.data.uid == uid &&
          request.resource.data.username == "" &&
          request.resource.data.usernameLower == "" &&
          request.resource.data.firstName == "" &&
          request.resource.data.lastName == "" &&
          request.resource.data.email == "" &&
          request.resource.data.role == "user" &&
          request.resource.data.accountStatus == "deleted" &&
          request.resource.data.provider == normalizedProfileProvider(resource.data) &&
          request.resource.data.displayName == "Deleted User" &&
          request.resource.data.gender == "" &&
          request.resource.data.bio == "" &&
          request.resource.data.deletedBy == uid &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "username",
            "usernameLower",
            "firstName",
            "lastName",
            "email",
            "role",
            "accountStatus",
            "displayName",
            "photoURL",
            "gender",
            "bio",
            "updatedAt",
            "deletedAt",
            "deletedBy",
            "deletedByEmail"
          ]);
      }

      allow get: if signedIn() &&
        (isSelf(uid) || isAdmin() || isActiveUserDoc(resource.data));
      allow list: if isAdmin();
      allow create: if isSelfProfileCreate();
      allow update: if isAdminManagedRoleUpdate() ||
        isAdminManagedDeleteUpdate() ||
        isSelfAuthorEnableUpdate() ||
        isSelfProfileUpdate() ||
        isSelfDeleteUpdate();
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      function isValidNotificationType(type) {
        return type == "post-approved" || type == "custom";
      }

      function isValidNotificationCategory(category) {
        return category == "general" || category == "creator";
      }

      function isValidNotificationAudience(audience) {
        return audience == "all" || audience == "single";
      }

      function hasAdminNotificationShape() {
        return request.resource.data.uid is string &&
          request.resource.data.uid.size() > 0 &&
          isValidNotificationType(request.resource.data.type) &&
          isValidNotificationCategory(request.resource.data.category) &&
          request.resource.data.title is string &&
          request.resource.data.title.size() > 0 &&
          request.resource.data.body is string &&
          request.resource.data.body.size() > 0 &&
          request.resource.data.postId is string &&
          request.resource.data.imageUrl is string &&
          (
            !request.resource.data.keys().hasAny(["audience"]) ||
            isValidNotificationAudience(request.resource.data.audience)
          ) &&
          (
            !request.resource.data.keys().hasAny(["pushEnabled"]) ||
            request.resource.data.pushEnabled is bool
          ) &&
          request.resource.data.isRead == false &&
          request.resource.data.isUserSeen == false &&
          request.resource.data.readAt == null &&
          request.resource.data.userSeenAt == null &&
          request.resource.data.keys().hasOnly([
            "uid",
            "type",
            "category",
            "audience",
            "pushEnabled",
            "title",
            "body",
            "postId",
            "imageUrl",
            "isRead",
            "isUserSeen",
            "createdAt",
            "readAt",
            "userSeenAt"
          ]);
      }

      function isAdminCustomNotificationCreate() {
        return request.resource.data.type == "custom" &&
          request.resource.data.postId == "" &&
          request.resource.data.keys().hasAll(["audience", "pushEnabled"]);
      }

      function isAdminPostApprovedNotificationCreate() {
        return request.resource.data.type == "post-approved" &&
          request.resource.data.category == "creator" &&
          request.resource.data.postId.size() > 0 &&
          !request.resource.data.keys().hasAny(["audience", "pushEnabled"]);
      }

      function isAdminNotificationCreate() {
        return isAdmin() &&
          hasAdminNotificationShape() &&
          (
            isAdminCustomNotificationCreate() ||
            isAdminPostApprovedNotificationCreate()
          );
      }

      function isSelfNotificationUpdate() {
        return signedIn() &&
          resource.data.uid == request.auth.uid &&
          request.resource.data.uid == resource.data.uid &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "isRead",
            "readAt",
            "isUserSeen",
            "userSeenAt"
          ]) &&
          request.resource.data.isRead == true &&
          (
            !request.resource.data.diff(resource.data).changedKeys().hasAny(["isUserSeen"]) ||
            request.resource.data.isUserSeen == true
          );
      }

      allow get, list: if (signedIn() && resource.data.uid == request.auth.uid) || isAdmin();
      allow create: if isAdminNotificationCreate();
      allow update: if isSelfNotificationUpdate() || isAdmin();
      allow delete: if (signedIn() && resource.data.uid == request.auth.uid) || isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
