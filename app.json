{
  "expo": {
    "name": "DevGeet",
    "slug": "devgeet",
    "version": "1.1",
    "versionCode": 4,
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "devgeet",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.panditnaman.devgeet",
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EEF0F3",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.panditnaman.devgeet",
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.VIBRATE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "@react-native-google-signin/google-signin/app.plugin.js",
        {
          "iosUrlScheme": "com.googleusercontent.apps.180784231307-n1ukgc3u0bpfl3esv1kih50ek7uorsuq"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#EEF0F3",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200,
            "resizeMode": "cover"
          }
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "panditnaman",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "25df2d56-b937-44f9-b075-eda096025e79"
      }
    }
  }
}
