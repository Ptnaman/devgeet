{
  "expo": {
    "name": "DevGeet",
    "slug": "devgeet",
    "version": "1.1.26",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "devgeet",
    "userInterfaceStyle": "automatic",
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/25df2d56-b937-44f9-b075-eda096025e79",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.panditnaman.devgeet",
      "usesAppleSignIn": true,
      "icon": "./assets/images/icon.png",
      "associatedDomains": ["applinks:dev-geet.firebaseapp.com"]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EEF0F3",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.panditnaman.devgeet",
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "resize",
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "predictiveBackGestureEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            {
              "scheme": "https",
              "host": "dev-geet.firebaseapp.com"
            }
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin/app.plugin.js",
        {
          "iosUrlScheme": "com.googleusercontent.apps.180784231307-n1ukgc3u0bpfl3esv1kih50ek7uorsuq"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#EEF0F3",
          "image": "./assets/images/splash-icon.png",
          "dark": {
            "backgroundColor": "#15171C",
            "image": "./assets/images/splash-icon.png"
          },
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ],
      "expo-image",
      "expo-notifications",
      "expo-updates"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "panditnaman",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "25df2d56-b937-44f9-b075-eda096025e79"
      }
    }
  }
}
